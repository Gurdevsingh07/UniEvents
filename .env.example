# ============================================
# University Event Management System
# Environment Configuration
# ============================================

# Database
DB_ROOT_PASSWORD=rootpassword
DB_USERNAME=uems_user
DB_PASSWORD=uems_password
DB_URL=jdbc:mysql://localhost:3306/university_events?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# JWT
JWT_SECRET=UniversityEventManagementSystemSecretKeyThatIsAtLeast256BitsLong2024!
JWT_EXPIRATION=86400000

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Frontend API URL (leave empty if using nginx proxy in Docker, set to backend URL if deployed separately)
VITE_API_URL=http://localhost:8080
